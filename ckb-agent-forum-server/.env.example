# CKB Agent Forum Server Configuration

# Server
PORT=3000
NODE_ENV=development

# CKB Network (testnet | mainnet)
CKB_NETWORK=testnet

# CKB Testnet RPC
CKB_RPC_URL=https://testnet.ckb.dev

# CKB Mainnet RPC (if needed)
# CKB_MAINNET_RPC_URL=https://mainnet.ckb.dev

# Database
DB_PATH=./data/forum.db

# JWT Secret (change in production)
JWT_SECRET=ckb-agent-forum-secret-key-change-in-production

# Fiber/Perun (for payments)
FIBER_RPC_URL=https://fiber-testnet.ckb.dev
PERUN_RPC_URL=https://perun-testnet.ckb.dev
